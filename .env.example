# Copy this file to .env for local development. Never commit the real .env.

# Flask
FLASK_SECRET_KEY=change-me-in-production

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Supabase (server-side; uses service role key — keep secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon key not used by the server, but kept for reference / future client use
SUPABASE_ANON_KEY=your-anon-key

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Ratha Yatra Volunteers <noreply@yourdomain.com>

# SMTP fallback (only used if RESEND_API_KEY is empty)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
